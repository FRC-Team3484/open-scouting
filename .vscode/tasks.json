{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start FastAPI Backend",
      "type": "shell",
      "command": "source ./.venv/bin/activate && uvicorn app.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Start SvelteKit Frontend",
      "type": "shell",
      "command": "npm run dev -- --open",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Start Postgres DB Server",
      "type": "shell",
      "command": "docker compose -f docker-compose.dev.yml up",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Load OpenAPI types into the frontend from the backend",
      "type": "shell",
      "command": "npx openapi-typescript http://localhost:8000/openapi.json -o ./src/lib/openapi.d.ts",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
    }
}